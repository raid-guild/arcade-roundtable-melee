# Local development
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0

# Required for sessions and websocket auth.
# Use long random values in deployed environments.
SESSION_SECRET=change-me-to-a-long-random-secret-32chars
SOCKET_TOKEN_SECRET=change-me-to-a-different-long-random-secret

# Local-only Portal bypass. Never enable this in production.
ALLOW_DEV_LOGIN=true
DEV_PLAYER_HANDLE=local-raider

# Portal signed launch configuration.
# Required for real Portal launches.
MODULE_LAUNCH_SECRET=
PORTAL_ISSUER=https://portal.raidguild.org
MODULE_SLUG=roundtable-melee
PORTAL_MODULES_URL=https://portal.raidguild.org/modules

# Database. Optional for local gray-box play; required for Portal callback
# player upserts and match-end persistence.
DATABASE_URL=

# Gameplay tuning lives in game/shared/config-values.mjs.
# Edit that file and redeploy to change match timing, scoring, spawn rates,
# combat tuning, input rate limits, or arena bounds.

# Client-side debug drawing.
NEXT_PUBLIC_SHOW_HITBOXES=false
