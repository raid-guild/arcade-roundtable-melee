# Local development
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0

# Required for sessions and websocket auth.
# Use long random values in deployed environments.
SESSION_SECRET=change-me-to-a-long-random-secret-32chars
SOCKET_TOKEN_SECRET=change-me-to-a-different-long-random-secret

# Local-only Portal bypass. Never enable this in production.
ALLOW_DEV_LOGIN=true
DEV_PLAYER_HANDLE=local-raider

# Portal signed launch configuration.
# Required for real Portal launches.
MODULE_LAUNCH_SECRET=
PORTAL_ISSUER=https://portal.raidguild.org
MODULE_SLUG=roundtable-melee
PORTAL_MODULES_URL=https://portal.raidguild.org/modules

# Database. Optional for local gray-box play; required for Portal callback
# player upserts and match-end persistence.
DATABASE_URL=

# Gameplay tuning overrides.
LOBBY_COUNTDOWN_SECONDS=15
MATCH_DURATION_SECONDS=180
FINAL_RESULTS_SECONDS=30
MAX_PLAYERS=10
FREEZE_SECONDS=15
PLAYER_MAX_HEALTH=100
HAM_HEAL_AMOUNT=25
SLAY_SCORE=200
DEATH_SCORE=-150
CHEST_SCORE=50
HAM_SPAWN_MIN_SECONDS=15
HAM_SPAWN_MAX_SECONDS=60
MAX_ACTIVE_HAMS=2
CHEST_SPAWN_MIN_SECONDS=15
CHEST_SPAWN_MAX_SECONDS=60
MAX_ACTIVE_CHESTS=2
CHEST_MIN_HITS=3
CHEST_MAX_HITS=5
ATTACK_DAMAGE=25
ATTACK_COOLDOWN_MS=580
ATTACK_ACTIVE_MS=150
MAX_INPUT_MESSAGES_PER_SECOND=45

# Client-side debug drawing.
NEXT_PUBLIC_SHOW_HITBOXES=false

# Pixel-coordinate bounds for the walkable floor within the arena image.
PLAYFIELD_MIN_X=46
PLAYFIELD_MAX_X=674
PLAYFIELD_MIN_Y=126
PLAYFIELD_MAX_Y=574
